default_platform(:ios)

# Bundle ID + scheme + project — single source of truth for both lanes.
BUNDLE_ID = "com.telecmux.app"
PROJECT   = "Telecmux.xcodeproj"
SCHEME    = "Telecmux"

platform :ios do
  before_all do
    setup_ci if ENV["CI"]
  end

  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true,
    )

    build_number = Time.now.strftime("%Y%m%d%H%M")
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: build_number,
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']} CODE_SIGN_STYLE=Automatic -allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"],
      },
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
    )
  end

  desc "Build and submit for App Store review"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_ISSUER_ID"],
      key_content: ENV["APP_STORE_CONNECT_API_KEY"],
      is_key_content_base64: true,
    )

    build_number = Time.now.strftime("%Y%m%d%H%M")
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: build_number,
    )

    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      clean: true,
      xcargs: "DEVELOPMENT_TEAM=#{ENV['TEAM_ID']} CODE_SIGN_STYLE=Automatic -allowProvisioningUpdates",
      export_options: {
        signingStyle: "automatic",
        teamID: ENV["TEAM_ID"],
      },
    )

    upload_to_app_store(
      api_key: api_key,
      skip_metadata: false,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: true,
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end
end
